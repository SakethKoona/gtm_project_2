# ─── Database (required) ─────────────────────────────────────────────────────
DATABASE_URL="postgres://<user>@localhost:5432/sales_automation"

# ─── Compliance / dialer knobs (optional; sensible defaults in code) ─────────
CALLING_HOURS_START=8
CALLING_HOURS_END=21
PER_LEAD_DAILY_CAP=3
OVERDIAL_RATIO=1.0
DNC_PROVIDER=stub

# ─── Telephony (required only to place REAL calls) ───────────────────────────
# Leave these UNSET to run in safe simulation mode (no real calls, $0).
# Set all four to switch the dialer to real Twilio calls.
#
# From your Twilio console (https://console.twilio.com):
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# A Twilio phone number you own, in E.164, e.g. +14045550123
TWILIO_NUMBER=
# Public base URL of the telephony server that Twilio can reach.
# In dev, run `ngrok http 4000` and paste the https URL here (no trailing slash).
PUBLIC_URL=

# Port the always-on telephony server listens on (default 4000).
TELEPHONY_PORT=4000

# ─── Optional: live IVR navigation over the Media Stream ─────────────────────
# Without this, real calls still reach a human (via Twilio AMD) and bridge to a
# rep, but cannot auto-navigate "press 1 for sales" menus.
DEEPGRAM_API_KEY=
